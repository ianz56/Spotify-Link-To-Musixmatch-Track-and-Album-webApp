#: mxm.py:377
#, python-format
msgid ""
"This track may having two pages with the same ISRC, the other <a class"
"=\"card-link\" href=\"%(track_url)s\" target=\"_blank\">page</a> from <a "
"class=\"card-link\" "
"href=\"https://www.musixmatch.com/album/%(artist_id)s/%(album_id)s\" "
"target=\"_blank\">album</a>."
msgstr ""
"Lagu ieu sigana ngagaduhan dua kaca nu ISRC-na sami, <a class=\"card-"
"link\" href=\"%(track_url)s\" target=\"_blank\">kaca</a> lian ti <a class"
"=\"card-link\" "
"href=\"https://www.musixmatch.com/album/%(artist_id)s/%(album_id)s\" "
"target=\"_blank\">album</a>."

#: mxm.py:385
#, python-format
msgid ""
"This track may be facing an ISRC issue as the Spotify ID is connected to "
"another <a class=\"card-link\" href=\"%(track_url)s\" "
"target=\"_blank\">page</a> from <a class=\"card-link\" "
"href=\"https://www.musixmatch.com/album/%(artist_id)s/%(album_id)s\" "
"target=\"_blank\">album</a>."
msgstr ""
"Lagu ieu siga aya masalah ISRC sabab ID Spotify nyambung ka <a class"
"=\"card-link\" href=\"%(track_url)s\" target=\"_blank\">kaca</a> lian ti "
"ieu <a class=\"card-link\" "
"href=\"https://www.musixmatch.com/album/%(artist_id)s/%(album_id)s\" "
"target=\"_blank\">album</a>."

